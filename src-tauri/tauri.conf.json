{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri-v2-schema/main/schema.json",
  "productName": "Censor Bars",
  "version": "0.1.0",
  "identifier": "dev.nexusfoundry.censor-bars",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "control-panel",
        "title": "Censor Bars",
        "width": 380,
        "height": 500,
        "resizable": true,
        "center": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "Censor Bars"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  }
}
